# Dependencies
node_modules/

# Build output is intentionally committed so the tool can be installed straight
# from GitHub (npm install -g github:ccarpiog/claude-sync) without a build step.
# Rebuild with `npm run build` and commit dist/ whenever src/ changes — CI fails
# if the committed dist/ is stale.

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# Environment
.env
.env.local
