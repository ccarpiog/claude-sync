{
  "name": "claude-sync",
  "version": "2.0.0",
  "description": "Sync Claude Code configuration across machines using Git (a fork of jean-claude by Mike Veerman)",
  "author": "Mike Veerman (original author of jean-claude)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ccarpiog/claude-sync"
  },
  "homepage": "https://github.com/ccarpiog/claude-sync#readme",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "claude-sync": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "./test-integration.sh",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepare": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "dotfiles",
    "sync",
    "cli",
    "configuration"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  }
}
